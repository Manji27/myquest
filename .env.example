# Synchronisation cloud (Neon) — copie ce fichier en `.env` et remplis les valeurs.
# Voir NEON.md pour la procédure complète.
#
# VITE_NEON_AUTH_URL     : URL du service Neon Auth (Console Neon → Auth)
# VITE_NEON_DATA_API_URL : URL du Data API, terminée par /rest/v1 (Console Neon → Data API)
VITE_NEON_AUTH_URL=https://xxxxxxxx.auth.neon.tech
VITE_NEON_DATA_API_URL=https://xxxxxxxx.dataapi.neon.tech/rest/v1

# Rappels push — clé publique injectée au build Cloudflare (voir PUSH.md)
VITE_VAPID_PUBLIC=BJ...
